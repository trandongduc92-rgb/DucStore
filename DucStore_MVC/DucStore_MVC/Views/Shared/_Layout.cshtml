@using Microsoft.AspNetCore.Http
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var cartJson = HttpContextAccessor.HttpContext?.Session.GetString("Cart");
    var cartItems = string.IsNullOrEmpty(cartJson) ? new List<CartItem>() : System.Text.Json.JsonSerializer.Deserialize<List<CartItem>>(cartJson);
    var cartCount = cartItems?.Sum(i => i.SoLuong) ?? 0;
    var cartTotal = cartItems?.Sum(i => i.ThanhTien) ?? 0;
    
    var customerJson = HttpContextAccessor.HttpContext?.Session.GetString("Customer");
    var currentUser = string.IsNullOrEmpty(customerJson) ? null : System.Text.Json.JsonSerializer.Deserialize<KhachHang>(customerJson);
    
    var adminJson = HttpContextAccessor.HttpContext?.Session.GetString("Admin");
    var currentAdmin = string.IsNullOrEmpty(adminJson) ? null : System.Text.Json.JsonSerializer.Deserialize<TaiKhoanAdmin>(adminJson);
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DucStore - Apple Authorized Store</title>
    <!-- Tailwind CSS Play CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>
<body class="bg-[#F5F5F7] font-sans selection:bg-blue-500/30 flex flex-col min-h-screen">
    <!-- Action Notifications -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div id="toast-success" class="fixed top-4 right-4 z-50 flex items-center w-full max-w-xs p-4 text-gray-800 bg-white rounded-xl shadow-xl transition-all duration-300" role="alert">
            <div class="inline-flex items-center justify-center flex-shrink-0 w-8 h-8 text-green-500 bg-green-100 rounded-lg">
                <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5Zm3.707 8.207-4 4a1 1 0 0 1-1.414 0l-2-2a1 1 0 0 1 1.414-1.414L9 10.586l3.293-3.293a1 1 0 0 1 1.414 1.414Z"/>
                </svg>
            </div>
            <div class="ms-3 text-sm font-medium">@TempData["SuccessMessage"]</div>
            <button type="button" onclick="document.getElementById('toast-success').remove()" class="ms-auto -mx-1.5 -my-1.5 bg-white text-gray-400 hover:text-gray-900 rounded-lg p-1.5 hover:bg-gray-100 inline-flex items-center justify-center h-8 w-8">
                <span class="sr-only">Đóng</span>
                <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                </svg>
            </button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div id="toast-error" class="fixed top-4 right-4 z-50 flex items-center w-full max-w-xs p-4 text-gray-800 bg-white rounded-xl shadow-xl transition-all duration-300" role="alert">
            <div class="inline-flex items-center justify-center flex-shrink-0 w-8 h-8 text-red-500 bg-red-100 rounded-lg">
                <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5Zm3.707 11.793a1 1 0 1 1-1.414 1.414L10 11.414l-2.293 2.293a1 1 0 0 1-1.414-1.414L8.586 10 6.293 7.707a1 1 0 0 1 1.414-1.414L10 8.586l2.293-2.293a1 1 0 0 1 1.414 1.414L11.414 10l2.293 2.293Z"/>
                </svg>
            </div>
            <div class="ms-3 text-sm font-medium">@TempData["ErrorMessage"]</div>
            <button type="button" onclick="document.getElementById('toast-error').remove()" class="ms-auto -mx-1.5 -my-1.5 bg-white text-gray-400 hover:text-gray-900 rounded-lg p-1.5 hover:bg-gray-100 inline-flex items-center justify-center h-8 w-8">
                <span class="sr-only">Đóng</span>
                <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                </svg>
            </button>
        </div>
    }

    <!-- Floating Nav matching React Demo -->
    <div class="sticky top-6 z-50 max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 mb-8 transition-transform duration-500 ease-out">
        <div class="bg-white/80 backdrop-blur-xl border border-gray-200/50 shadow-[0_8px_30px_rgb(0,0,0,0.08)] rounded-full p-2 flex items-center justify-between">
            <div class="flex items-center space-x-1">
                <a href="/" class="px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 @(string.IsNullOrEmpty((string)ViewBag.SelectedCategory) ? "bg-blue-500/10 text-blue-600 shadow-sm" : "text-gray-600 hover:bg-gray-100 hover:text-gray-900")">
                    Tất cả
                </a>
                
                <div class="h-4 w-[1px] bg-gray-200 mx-2"></div>
                
                <a href="/?category=iphone" class="px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 @((string)ViewBag.SelectedCategory == "iphone" ? "bg-blue-500/10 text-blue-600 shadow-sm" : "text-gray-600 hover:bg-gray-100 hover:text-gray-900")">
                    iPhone
                </a>
                
                <a href="/?category=ipad" class="px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-300 @((string)ViewBag.SelectedCategory == "ipad" ? "bg-blue-500/10 text-blue-600 shadow-sm" : "text-gray-600 hover:bg-gray-100 hover:text-gray-900")">
                    iPad
                </a>
            </div>

            <div class="flex items-center space-x-2">
                <div class="h-4 w-[1px] bg-gray-200 mr-2"></div>
                
                <button onclick="toggleCartModal(true)" class="flex items-center space-x-2 px-4 py-2.5 rounded-full text-sm font-medium text-gray-700 hover:bg-gray-100 transition-colors">
                    <i data-lucide="shopping-cart" class="w-4 h-4"></i>
                    <span class="hidden sm:inline">Giỏ hàng</span>
                    @if (cartCount > 0)
                    {
                        <span class="text-xs font-semibold text-blue-600">(@cartCount)</span>
                    }
                </button>

                @if (currentAdmin != null)
                {
                    <a href="/Admin/Index" class="flex items-center space-x-2 px-4 py-2.5 rounded-full text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 transition-colors shadow-md shadow-blue-500/20">
                        <i data-lucide="shield-check" class="w-4 h-4"></i>
                        <span class="hidden sm:inline">Quản trị</span>
                    </a>
                }
                else
                {
                    <button onclick="@(currentUser != null ? "window.location.href='/Auth/Logout'" : "toggleAuthModal(true)")" class="flex items-center space-x-2 px-4 py-2.5 rounded-full text-sm font-medium text-gray-600 hover:bg-gray-100 transition-colors">
                        <i data-lucide="user" class="w-4 h-4"></i>
                        <span class="hidden sm:inline truncate max-w-[80px]">
                            @(currentUser != null ? currentUser.TenKhachHang.Split(' ').Last() : "Tài khoản")
                        </span>
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- Main Content Area -->
    <main class="flex-grow">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-12 mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-4 gap-8">
            <div class="col-span-1 md:col-span-2">
                <span class="text-xl font-bold tracking-tight">DUCSTORE</span>
                <p class="text-gray-400 text-sm mt-3 max-w-sm">Hệ thống phân phối ủy quyền chính thức các sản phẩm Apple của đại lý DucStore tại Việt Nam. Uy tín, chất lượng và dịch vụ bảo hành chuẩn mực 5 sao.</p>
            </div>
            <div>
                <h4 class="font-semibold text-sm tracking-wider uppercase mb-3">Hỗ Trợ Khách Hàng</h4>
                <ul class="space-y-2 text-sm text-gray-400">
                    <li><a href="#" class="hover:text-white transition">Chính sách bảo hành</a></li>
                    <li><a href="#" class="hover:text-white transition">Chính sách vận chuyển</a></li>
                    <li><a href="#" class="hover:text-white transition">Điều khoản mua sắm</a></li>
                </ul>
            </div>
            <div>
                <h4 class="font-semibold text-sm tracking-wider uppercase mb-3">Tài Khoản & Admin</h4>
                <ul class="space-y-2 text-sm text-gray-400">
                    <li><button onclick="toggleAuthModal(true)" class="hover:text-white text-left transition">Đăng nhập / Đăng ký</button></li>
                    <li><button onclick="toggleAdminModal(true)" class="hover:text-white text-left text-red-400 font-medium transition">Đăng nhập Admin</button></li>
                </ul>
            </div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 border-t border-gray-800 text-center text-xs text-gray-500 pt-6 mt-8">
            &copy; 2026 DucStore. All rights reserved. ASP.NET Core MVC Edition.
        </div>
    </footer>

    <!-- ================= MODAL AUTH (LOGIN / REGISTER) ================= -->
    <div id="auth-modal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="toggleAuthModal(false)"></div>
        <div class="relative bg-white w-full max-w-md p-8 rounded-2xl shadow-2xl mx-4 transition-all duration-300">
            <button onclick="toggleAuthModal(false)" class="absolute top-4 right-4 text-gray-400 hover:text-gray-900">
                <i data-lucide="x" class="w-6 h-6"></i>
            </button>

            <!-- Login Segment -->
            <div id="login-segment">
                <h3 class="text-xl font-bold text-gray-900 mb-2">Đăng Nhập Khách Hàng</h3>
                <p class="text-sm text-gray-500 mb-6 font-light">Vui lòng nhập thông tin đăng nhập của bạn để tiếp tục mua sắm.</p>
                <form asp-controller="Auth" asp-action="Login" method="post" class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 uppercase tracking-wider mb-1.5">Địa chỉ Email</label>
                        <input type="email" name="email" required placeholder="example@gmail.com" class="w-full px-4 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 uppercase tracking-wider mb-1.5">Mật khẩu</label>
                        <input type="password" name="password" required placeholder="******" class="w-full px-4 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
                    </div>
                    <button type="submit" class="w-full py-3 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-xl shadow-lg hover:shadow-blue-500/20 active:scale-[0.98] transition">Đăng Nhập</button>
                    <div class="text-center text-xs text-gray-500 mt-4">
                        Chưa có tài khoản? <button type="button" onclick="switchToRegister(true)" class="text-blue-600 font-semibold hover:underline">Đăng ký ngay</button>
                    </div>
                </form>
            </div>

            <!-- Register Segment -->
            <div id="register-segment" class="hidden">
                <h3 class="text-xl font-bold text-gray-900 mb-2">Đăng Ký Khách Hàng</h3>
                <p class="text-sm text-gray-500 mb-6 font-light">Tạo tài khoản mới để nhận nhiều ưu đãi.</p>
                <form asp-controller="Auth" asp-action="Register" method="post" class="space-y-4 max-h-[420px] overflow-y-auto pr-2">
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 uppercase tracking-wider mb-1.5">Họ và Tên</label>
                        <input type="text" name="name" required placeholder="Nguyễn Văn A" class="w-full px-4 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 uppercase tracking-wider mb-1.5">Địa chỉ Email</label>
                        <input type="email" name="email" required placeholder="example@gmail.com" class="w-full px-4 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 uppercase tracking-wider mb-1.5">Số điện thoại</label>
                        <input type="tel" name="phone" required placeholder="0987654321" class="w-full px-4 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 uppercase tracking-wider mb-1.5">Mật khẩu</label>
                        <input type="password" name="password" required placeholder="******" class="w-full px-4 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-700 uppercase tracking-wider mb-1.5">Địa chỉ nhận hàng</label>
                        <input type="text" name="address" required placeholder="Số nhà, Tên đường, Quận, Thành phố" class="w-full px-4 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
                    </div>
                    <button type="submit" class="w-full py-3 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-xl shadow-lg hover:shadow-blue-500/20 active:scale-[0.98] transition">Đăng Ký</button>
                    <div class="text-center text-xs text-gray-500 mt-4">
                        Đã có tài khoản? <button type="button" onclick="switchToRegister(false)" class="text-blue-600 font-semibold hover:underline">Đăng nhập</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ================= MODAL ADMIN LOGIN ================= -->
    <div id="admin-modal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="toggleAdminModal(false)"></div>
        <div class="relative bg-white w-full max-w-sm p-8 rounded-2xl shadow-2xl mx-4">
            <button onclick="toggleAdminModal(false)" class="absolute top-4 right-4 text-gray-400 hover:text-gray-900">
                <i data-lucide="x" class="w-6 h-6"></i>
            </button>
            <h3 class="text-xl font-bold text-red-600 mb-2 flex items-center space-x-2">
                <i data-lucide="shield-alert" class="w-6 h-6"></i>
                <span>Trang Quản Trị</span>
            </h3>
            <p class="text-xs text-gray-500 mb-6">Đăng đăng nhập bằng tài khoản quản trị hệ thống DucStore.</p>
            <form asp-controller="Auth" asp-action="AdminLogin" method="post" class="space-y-4">
                <div>
                    <label class="block text-xs font-semibold text-gray-700 uppercase tracking-wider mb-1.5">Tên đăng nhập</label>
                    <input type="text" name="username" required placeholder="admin" class="w-full px-4 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500">
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-700 uppercase tracking-wider mb-1.5">Mật khẩu</label>
                    <input type="password" name="password" required placeholder="******" class="w-full px-4 py-2.5 text-sm border border-gray-200 rounded-xl focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500">
                </div>
                <button type="submit" class="w-full py-3 text-sm font-semibold text-white bg-red-600 hover:bg-red-700 rounded-xl shadow-lg hover:shadow-red-500/20 transition">Đăng Nhập Admin</button>
                <div class="text-center text-[11px] text-gray-400">
                    Mặc định: <b>admin</b> / <b>admin123</b>
                </div>
            </form>
        </div>
    </div>

    <!-- ================= SHOPPING CART SIDE DRAWER ================= -->
    <div id="cart-modal" class="fixed inset-y-0 right-0 w-full max-w-md bg-white shadow-2xl z-50 flex flex-col translate-x-full transition-transform duration-300">
        <!-- Close overlay -->
        <div class="fixed inset-0 -z-10 bg-black/40 backdrop-blur-sm transition-opacity opacity-0 hidden" id="cart-overlay" onclick="toggleCartModal(false)"></div>
        
        <!-- Header -->
        <div class="p-6 border-b border-gray-100 flex items-center justify-between">
            <div class="flex items-center space-x-2">
                <i data-lucide="shopping-bag" class="w-5.5 h-5.5 text-blue-600"></i>
                <h3 class="text-lg font-bold text-gray-900">Giỏ Hàng Của Bạn</h3>
                <span class="bg-blue-100 text-blue-800 text-xs px-2 py-0.5 rounded-full font-semibold">@cartCount</span>
            </div>
            <button onclick="toggleCartModal(false)" class="p-1 text-gray-400 hover:text-gray-900 rounded-lg">
                <i data-lucide="x" class="w-6 h-6"></i>
            </button>
        </div>

        <!-- Cart Items List -->
        <div class="flex-grow overflow-y-auto p-6 space-y-4">
            @if (cartItems == null || !cartItems.Any())
            {
                <div class="text-center py-20">
                    <div class="inline-flex p-4 rounded-full bg-gray-50 text-gray-400 mb-4">
                        <i data-lucide="shopping-bag" class="w-10 h-10"></i>
                    </div>
                    <p class="text-gray-500 text-sm">Giỏ hàng của bạn đang trống</p>
                    <button onclick="toggleCartModal(false)" class="text-blue-600 text-xs font-semibold hover:underline mt-2">Tiếp tục mua hàng</button>
                </div>
            }
            else
            {
                @foreach (var item in cartItems)
                {
                    <div class="flex items-center space-x-4 p-3 bg-gray-50 rounded-xl relative hover:bg-gray-100/60 transition">
                        <img src="/images/@item.SanPham.HinhAnh" alt="@item.SanPham.TenSanPham" class="w-14 h-14 bg-white border border-gray-200 rounded-lg object-contain">
                        <div class="flex-1 min-w-0">
                            <h4 class="text-xs font-bold text-gray-900 truncate">@item.SanPham.TenSanPham</h4>
                            <p class="text-xs text-blue-600 font-bold mt-1">@String.Format("{0:N0} đ", item.SanPham.Gia)</p>
                            
                            <!-- Quantity adjuster form -->
                            <div class="flex items-center space-x-1.5 mt-2">
                                <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="flex items-center border border-gray-300 rounded-md overflow-hidden bg-white">
                                    <input type="hidden" name="productCode" value="@item.SanPham.MaSanPham" />
                                    <button type="submit" name="quantity" value="@(item.SoLuong - 1)" class="px-2 py-0.5 text-xs text-gray-500 hover:bg-gray-100">-</button>
                                    <span class="px-3 text-xs font-medium text-gray-900">@item.SoLuong</span>
                                    <button type="submit" name="quantity" value="@(item.SoLuong + 1)" class="px-2 py-0.5 text-xs text-gray-500 hover:bg-gray-100">+</button>
                                </form>
                            </div>
                        </div>
                        <form asp-controller="Cart" asp-action="RemoveFromCart" method="post" class="absolute top-2 right-2">
                            <input type="hidden" name="productCode" value="@item.SanPham.MaSanPham" />
                            <button type="submit" class="text-gray-400 hover:text-red-500 transition">
                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                            </button>
                        </form>
                    </div>
                }
            }
        </div>

        <!-- Checkout Form / Footer -->
        @if (cartItems != null && cartItems.Any())
        {
            <div class="border-t border-gray-100 p-6 bg-gray-50 space-y-4">
                <div class="flex justify-between items-center text-sm">
                    <span class="text-gray-600 font-medium">Tổng hóa đơn:</span>
                    <span class="text-lg font-black text-blue-600">@String.Format("{0:N0} đ", cartTotal)</span>
                </div>
                
                <form asp-controller="Cart" asp-action="Checkout" method="post" class="space-y-3">
                    @if (currentUser == null)
                    {
                        <div>
                            <input type="text" name="name" required placeholder="Họ và tên khách mua..." class="w-full px-3.5 py-2 text-xs border border-gray-200 rounded-lg focus:outline-none focus:border-blue-500">
                        </div>
                        <div>
                            <input type="tel" name="phone" required placeholder="Số điện thoại..." class="w-full px-3.5 py-2 text-xs border border-gray-200 rounded-lg focus:outline-none focus:border-blue-500">
                        </div>
                        <div>
                            <input type="text" name="address" required placeholder="Địa chỉ giao hàng..." class="w-full px-3.5 py-2 text-xs border border-gray-200 rounded-lg focus:outline-none focus:border-blue-500">
                        </div>
                    }
                    else
                    {
                        <div class="bg-blue-50/50 p-3 rounded-lg border border-blue-100 text-xs text-blue-800">
                            Hệ thống sẽ tự động sử dụng thông tin của quý khách: <br>
                            <b>@currentUser.TenKhachHang</b> (@currentUser.DienThoai) tại <b>@currentUser.DiaChi</b>.
                        </div>
                    }

                    <button type="submit" class="w-full py-3 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-xl shadow-lg shadow-blue-500/10 block text-center active:scale-[0.99] transition">Thanh Toán Ngay</button>
                </form>
            </div>
        }
    </div>

    <!-- Lucide Icons CDN Script -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        lucide.createIcons();

        function toggleAuthModal(show) {
            const modal = document.getElementById('auth-modal');
            if (show) {
                modal.classList.remove('hidden');
            } else {
                modal.classList.add('hidden');
            }
        }

        function switchToRegister(isRegister) {
            const loginSeg = document.getElementById('login-segment');
            const registerSeg = document.getElementById('register-segment');
            if (isRegister) {
                loginSeg.classList.add('hidden');
                registerSeg.classList.remove('hidden');
            } else {
                loginSeg.classList.remove('hidden');
                registerSeg.classList.add('hidden');
            }
        }

        function toggleAdminModal(show) {
            const modal = document.getElementById('admin-modal');
            if (show) {
                modal.classList.remove('hidden');
            } else {
                modal.classList.add('hidden');
            }
        }

        function toggleCartModal(show) {
            const cartPanel = document.getElementById('cart-modal');
            const overlay = document.getElementById('cart-overlay');
            if (show) {
                cartPanel.classList.remove('translate-x-full');
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.add('opacity-100'), 50);
            } else {
                cartPanel.classList.add('translate-x-full');
                overlay.classList.remove('opacity-100');
                overlay.classList.add('hidden');
            }
        }
    </script>
</body>
</html>
