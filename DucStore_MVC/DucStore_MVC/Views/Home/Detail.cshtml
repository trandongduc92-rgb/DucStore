@model DucStore_MVC.Models.SanPham
@{
    var related = ViewBag.RelatedProducts as List<DucStore_MVC.Models.SanPham> ?? new List<SanPham>();
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    <nav class="flex text-xs text-gray-500 mb-8 space-x-1">
        <a href="/" class="hover:text-blue-600">Trang chủ</a>
        <span>/</span>
        <a href="/?category=@Model.MaDanhMuc" class="hover:text-blue-600 uppercase">@Model.MaDanhMuc</a>
        <span>/</span>
        <span class="text-gray-900 font-medium truncate">@Model.TenSanPham</span>
    </nav>

    <!-- Product Showcase grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 bg-white rounded-3xl p-8 md:p-12 border border-gray-100 shadow-sm">
        <!-- Visual display column -->
        <div class="flex items-center justify-center p-8 bg-slate-50 rounded-2xl border border-gray-100">
            <img src="/images/@Model.HinhAnh" alt="@Model.TenSanPham" class="max-h-[380px] object-contain drop-shadow-2xl">
        </div>

        <!-- Purchase & Info details column -->
        <div class="space-y-6 flex flex-col justify-center">
            <span class="inline-flex px-3 py-1 rounded-full text-[10px] font-extrabold uppercase tracking-widest bg-blue-50 text-blue-600">Sản Phẩm Apple Chính Hãng</span>
            
            <div class="space-y-1">
                <h1 class="text-2xl md:text-3.5xl font-extrabold text-gray-900 leading-tight">@Model.TenSanPham</h1>
                <p class="text-xs text-gray-400">Mã sản phẩm: <b class="text-slate-700">@Model.MaSanPham</b></p>
            </div>

            <div class="bg-gray-50/70 p-5 rounded-2xl border border-gray-100">
                <span class="text-xs text-gray-400 block mb-1">Giá bán ủy quyền</span>
                <span class="text-3xl font-black text-blue-600">@String.Format("{0:N0} đ", Model.Gia)</span>
                <div class="flex items-center space-x-2 mt-2 text-xs text-green-600 font-medium">
                    <i data-lucide="check-circle-2" class="w-4 h-4"></i>
                    <span>Sẵn hàng tại toàn bộ đại lý DucStore</span>
                </div>
            </div>

            <p class="text-gray-600 text-sm leading-relaxed font-light">@Model.MoTa</p>

            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="space-y-4 pt-4 border-t border-gray-100">
                <input type="hidden" name="productCode" value="@Model.MaSanPham" />
                
                <div class="flex items-center space-x-4">
                    <div class="space-y-1">
                        <label class="block text-[10px] font-bold text-gray-400 uppercase">Số Lượng</label>
                        <input type="number" name="quantity" value="1" min="1" max="10" 
                               class="w-20 px-3 py-2.5 border border-gray-200 rounded-xl focus:outline-none focus:ring-1 focus:ring-blue-500 font-bold text-center">
                    </div>

                    <div class="flex-grow pt-4">
                        <button type="submit" class="w-full py-3 px-6 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-xl shadow-lg shadow-blue-500/10 hover:shadow-blue-500/20 active:scale-[0.98] transition flex items-center justify-center space-x-2">
                            <i data-lucide="shopping-bag" class="w-5 h-5"></i>
                            <span>Thêm Vào Giỏ Hàng</span>
                        </button>
                    </div>
                </div>
            </form>

            <!-- Store Trust badges -->
            <div class="grid grid-cols-2 gap-4 pt-6 border-t border-gray-100 text-xs text-gray-500 font-light">
                <div class="flex items-center space-x-2">
                    <i data-lucide="shield" class="w-4 h-4 text-blue-600"></i>
                    <span>Bảo hành chính hãng 12 tháng</span>
                </div>
                <div class="flex items-center space-x-2">
                    <i data-lucide="truck" class="w-4 h-4 text-blue-600"></i>
                    <span>Miễn phí giao hàng toàn quốc</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Related Products -->
    @if (related.Count > 0)
    {
        <div class="mt-16 space-y-6">
            <h3 class="text-xl font-bold text-gray-900 tracking-tight">Sản phẩm tương tự</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
                @foreach (var prod in related)
                {
                    <div class="bg-white rounded-2xl border border-gray-100 p-5 shadow-sm hover:shadow-md hover:border-gray-200 transition duration-300 flex flex-col justify-between">
                        <!-- Product Visual -->
                        <div class="aspect-square bg-gray-50 rounded-xl flex items-center justify-center p-3">
                            <img src="/images/@prod.HinhAnh" alt="@prod.TenSanPham" class="max-h-full max-w-full object-contain filter drop-shadow">
                        </div>
                        <div class="mt-4 flex-grow">
                            <h4 class="text-xs font-bold text-gray-900 hover:text-blue-600 transition truncate">
                                <a href="/Home/Detail/@prod.MaSanPham">@prod.TenSanPham</a>
                            </h4>
                            <p class="text-xs text-blue-600 font-extrabold mt-1">@String.Format("{0:N0} đ", prod.Gia)</p>
                        </div>
                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mt-4">
                            <input type="hidden" name="productCode" value="@prod.MaSanPham" />
                            <button type="submit" class="w-full py-2 bg-gray-50 hover:bg-blue-50 text-gray-600 hover:text-blue-600 font-semibold rounded-lg text-[11px] transition">Thêm nhanh</button>
                        </form>
                    </div>
                }
            </div>
        </div>
    }
</div>
