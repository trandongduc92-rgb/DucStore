@model List<DucStore_MVC.Models.SanPham>
@{
    var categories = ViewBag.Categories as List<DucStore_MVC.Models.DanhMuc> ?? new List<DanhMuc>();
    var selectedCategory = ViewBag.SelectedCategory as string;
    var searchQuery = ViewBag.SearchQuery as string;
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12 mt-6">
    <!-- SLIDER HERO BANNER MATCHING IMAGE 2 EXACTLY -->
    <div class="relative overflow-hidden bg-[#121214] rounded-[2rem] p-8 sm:p-12 md:p-16 flex flex-col md:flex-row items-center justify-between gap-12 shadow-2xl border border-white/5 group">
        <!-- Interactive Slide Navigation Arrows -->
        <button class="absolute left-6 top-1/2 -translate-y-1/2 w-12 h-12 bg-black/40 hover:bg-black/60 text-white rounded-full flex items-center justify-center transition-all opacity-0 group-hover:opacity-100 focus:outline-none z-20 border border-white/10">
            <svg class="w-5 h-5 animate-pulse" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        </button>
        <button class="absolute right-6 top-1/2 -translate-y-1/2 w-12 h-12 bg-black/40 hover:bg-black/60 text-white rounded-full flex items-center justify-center transition-all opacity-0 group-hover:opacity-100 focus:outline-none z-20 border border-white/10">
            <svg class="w-5 h-5 animate-pulse" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </button>

        <div class="relative z-10 max-w-xl space-y-6">
            <!-- Sparkles Hot badge -->
            <span class="inline-flex items-center space-x-2 px-4 py-1.5 rounded-full text-xs font-semibold bg-blue-500/10 text-blue-400 border border-blue-500/20 uppercase tracking-widest text-[10px]">
                <i data-lucide="sparkles" class="w-4.5 h-4.5 text-blue-400 animate-bounce"></i>
                <span>Sản phẩm hot</span>
            </span>

            <div class="space-y-4">
                <h1 class="text-4xl sm:text-5xl md:text-6xl font-black tracking-tight text-white leading-none">
                    iPhone 15 Pro Max
                </h1>
                <p class="text-xl sm:text-2xl font-bold text-gray-200">
                    Titanium. Siêu bền. Siêu nhẹ.
                </p>
                <p class="text-sm sm:text-base text-gray-400 leading-relaxed max-w-lg">
                    Trang bị chip A17 Pro bứt phá, nút Tác vụ tiện lợi và hệ thống camera siêu phân giải 5x Zoom quang học đỉnh cao.
                </p>
            </div>

            <div class="flex items-center space-x-4 pt-4">
                <a href="#store-products" class="px-8 py-3.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold rounded-full transition-all duration-300 transform active:scale-95 shadow-lg shadow-blue-500/20">
                    Khám phá ngay
                </a>
            </div>
        </div>

        <!-- Phone schematic outline mockup exactly as shown in screenshot -->
        <div class="relative z-10 w-full max-w-[320px] sm:max-w-md shrink-0 pointer-events-none opacity-90 transition-transform duration-700 hover:scale-105">
            <svg viewBox="0 0 400 350" class="w-full h-auto" xmlns="http://www.w3.org/2000/svg">
                <!-- Phone Silhouette Outline in fine gray lines -->
                <rect x="50" y="20" width="300" height="310" rx="40" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="4" />
                <rect x="55" y="25" width="290" height="300" rx="35" fill="none" stroke="rgba(255,255,255,0.03)" stroke-width="2" />
                <!-- Dynamic Island outline -->
                <rect x="140" y="45" width="120" height="24" rx="12" fill="rgba(255,255,255,0.08)" />
                <!-- Decorative diagram lines -->
                <line x1="50" y1="120" x2="350" y2="120" stroke="rgba(255,255,255,0.04)" stroke-width="1" />
                <line x1="50" y1="230" x2="350" y2="230" stroke="rgba(255,255,255,0.04)" stroke-width="1" />
                <!-- Futuristic watermark -->
                <text x="200" y="180" fill="rgba(255,255,255,0.02)" font-size="28" font-weight="900" text-anchor="middle">MOCKUP DESIGN</text>
            </svg>
        </div>

        <!-- Slider Pagination Indicator dots -->
        <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex items-center space-x-2.5 z-20">
            <div class="w-10 h-2 bg-blue-500 rounded-full transition-all"></div>
            <div class="w-2.5 h-2.5 bg-gray-600 rounded-full transition-all"></div>
        </div>
    </div>

    <!-- BENEFIT TRIPLE CARD SECTION MATCHING IMAGE 2 -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Benefit Card 1 -->
        <div class="bg-white rounded-2xl p-6 border border-gray-100 flex items-center space-x-5 shadow-sm hover:shadow-md transition-all duration-300">
            <div class="bg-blue-50 p-4 rounded-xl text-blue-600 shrink-0">
                <i data-lucide="shield-check" class="w-6 h-6"></i>
            </div>
            <div>
                <h4 class="text-xs font-bold text-gray-900 uppercase tracking-wider">100% Apple Authorized Dealer</h4>
                <p class="text-xs text-gray-500 mt-1 leading-relaxed">Hàng chính hãng VN/A nguyên seal bảo hành AppleCare chính hãng.</p>
            </div>
        </div>

        <!-- Benefit Card 2 -->
        <div class="bg-white rounded-2xl p-6 border border-gray-100 flex items-center space-x-5 shadow-sm hover:shadow-md transition-all duration-300">
            <div class="bg-amber-50 p-4 rounded-xl text-amber-600 shrink-0">
                <i data-lucide="zap" class="w-6 h-6"></i>
            </div>
            <div>
                <h4 class="text-xs font-bold text-gray-900 uppercase tracking-wider">Giao nhanh toàn quốc</h4>
                <p class="text-xs text-gray-500 mt-1 leading-relaxed">Chuyển phát bảo đảm siêu tốc 2H tại Hà Nội & HCM.</p>
            </div>
        </div>

        <!-- Benefit Card 3 -->
        <div class="bg-white rounded-2xl p-6 border border-gray-100 flex items-center space-x-5 shadow-sm hover:shadow-md transition-all duration-300">
            <div class="bg-indigo-50 p-4 rounded-xl text-indigo-600 shrink-0">
                <i data-lucide="award" class="w-6 h-6"></i>
            </div>
            <div>
                <h4 class="text-xs font-bold text-gray-900 uppercase tracking-wider">Bảo hành 1 đổi 1</h4>
                <p class="text-xs text-gray-500 mt-1 leading-relaxed">Chính sách 30 ngày đổi mới nếu phát sinh lỗi từ nhà sản xuất.</p>
            </div>
        </div>
    </div>

    <!-- CATEGORIES & PRODUCTS AREA -->
    <section id="store-products">
        <div class="flex items-center space-x-2 mb-8">
            <i data-lucide="sparkles" class="w-6 h-6 text-blue-500"></i>
            <h2 class="text-2xl font-semibold text-gray-900 tracking-tight">Danh mục sản phẩm</h2>
            <span class="text-sm font-medium text-gray-400 ml-2">(@(Model?.Count ?? 0) sản phẩm)</span>
        </div>

        <!-- Active Search Filter Indicator -->
        @if (!string.IsNullOrEmpty(searchQuery))
        {
            <div class="mb-6 inline-flex items-center space-x-2 bg-blue-50 border border-blue-100 text-blue-700 px-4 py-1.5 rounded-lg text-xs font-medium">
                <span>Kết quả tìm kiếm: "@searchQuery"</span>
                <a href="/" class="text-blue-500 hover:text-blue-900 font-bold ml-1">×</a>
            </div>
        }

        <!-- PRODUCTS GRID -->
        @if (Model == null || Model.Count == 0)
        {
            <div class="bg-white rounded-2xl border border-gray-100 p-20 text-center shadow-sm">
                <div class="inline-flex p-4 rounded-full bg-gray-50 text-gray-400 mb-4">
                    <i data-lucide="package-search" class="w-12 h-12"></i>
                </div>
                <h3 class="font-bold text-gray-900 text-lg">Không tìm thấy sản phẩm</h3>
                <p class="text-gray-500 text-xs mt-1">Xin vui lòng điều chỉnh bộ lọc hoặc từ khóa tìm kiếm của bạn.</p>
                <a href="/" class="inline-block mt-4 px-5 py-2.5 text-xs font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition shadow-md shadow-blue-500/10">Trở Về Trang Chủ</a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                @foreach (var prod in Model)
                {
                    <div class="p-5 bg-white rounded-[2rem] border border-gray-100 hover:border-blue-500/30 shadow-sm hover:shadow-[0_20px_40px_rgba(0,0,0,0.04)] transition-all duration-500 relative flex flex-col h-full group">
                        
                        <!-- Top Badges exactly as shown in Image 4 -->
                        <div class="flex items-center justify-between mb-4 w-full relative z-20">
                            <span class="bg-gray-100 text-gray-600 font-bold text-[9px] uppercase tracking-wider px-3 py-1 rounded-full">
                                IPHONE
                            </span>
                            <span class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-extrabold text-[9px] uppercase tracking-wider px-3 py-1 rounded-full flex items-center space-x-1 shadow-sm">
                                <i data-lucide="sparkles" class="w-3 h-3 text-white animate-pulse"></i>
                                <span>PREMIUM</span>
                            </span>
                        </div>

                        <!-- Image Container with Hover zoom + Eye circle overlay matching layout -->
                        <a href="/Home/Detail/@prod.MaSanPham" class="relative w-full aspect-[4/5] bg-gray-50 rounded-2xl mb-5 overflow-hidden flex items-center justify-center p-6 transition-colors duration-500 group-hover:bg-gray-100/60 block">
                            <img src="/images/@prod.HinhAnh" alt="@prod.TenSanPham" class="w-full h-full object-contain filter drop-shadow-md transition-transform duration-500 ease-out group-hover:scale-105" />
                            
                            <!-- Middle Eye Icon Container -->
                            <div class="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                                <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-lg transform scale-75 group-hover:scale-100 transition-transform duration-300">
                                    <i data-lucide="eye" class="w-5 h-5 text-gray-800"></i>
                                </div>
                            </div>
                        </a>

                        <!-- Details Section & Spacing -->
                        <div class="flex-grow flex flex-col justify-between">
                            <div class="space-y-2">
                                <h3 class="text-base font-bold text-gray-900 leading-snug group-hover:text-blue-600 transition-colors">
                                    <a href="/Home/Detail/@prod.MaSanPham">@prod.TenSanPham</a>
                                </h3>
                                
                                <p class="text-lg font-black text-blue-600">
                                    @String.Format("{0:N0} đ", prod.Gia)
                                </p>
                                
                                <p class="text-xs text-gray-500 line-clamp-3 leading-relaxed mt-2 h-[54px]">
                                    @prod.MoTa
                                </p>
                            </div>

                            <div class="pt-4 mt-4 border-t border-gray-100 space-y-3.5">
                                <div class="text-[10px] font-bold text-gray-400 tracking-widest uppercase">
                                    DANH MỤC: <span class="text-blue-600 font-extrabold">@prod.MaDanhMuc</span>
                                </div>
                                
                                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="w-full">
                                    <input type="hidden" name="productCode" value="@prod.MaSanPham" />
                                    <button type="submit" class="w-full py-3.5 bg-[#0B355B] hover:bg-slate-900 text-white font-bold text-xs rounded-xl flex items-center justify-center space-x-2 shadow-sm transition-all duration-300 active:scale-[0.98] cursor-pointer">
                                        <i data-lucide="shopping-cart" class="w-4 h-4 text-white"></i>
                                        <span>Thêm vào giỏ hàng</span>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>
</div>
