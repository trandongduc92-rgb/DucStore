@model List<DucStore_MVC.Models.SanPham>
@{
    var categories = ViewBag.Categories as List<DucStore_MVC.Models.DanhMuc> ?? new List<DanhMuc>();
    var selectedCategory = ViewBag.SelectedCategory as string;
    var searchQuery = ViewBag.SearchQuery as string;
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12 mt-4">
    <!-- BANNER / HERO ENGAGE -->
    <div class="relative overflow-hidden bg-[#0B1528] rounded-[2rem] p-8 sm:p-12 md:p-16 flex flex-col md:flex-row items-center justify-between gap-12 shadow-2xl">
        <!-- Decorative gradient blur -->
        <div class="absolute -top-40 -right-40 w-96 h-96 bg-blue-500/20 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-purple-500/20 rounded-full blur-3xl"></div>
        
        <div class="relative z-10 max-w-xl space-y-6">
            <span class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-semibold bg-white/10 text-white/90 border border-white/10 backdrop-blur-sm">
                Apple Authorized Reseller
            </span>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-white leading-[1.1]">
                iPhone 15 Pro Max
                <br />
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400">
                đỉnh cao công nghệ
                </span>
            </h1>
            <p class="text-lg text-white/70 leading-relaxed font-light">
                Mở lối trải nghiệm với khung Titan siêu bền, chip A17 Pro hiệu năng không đối thủ cùng nút Tác vụ (Action button) hoàn toàn mới.
            </p>
            <div class="flex items-center space-x-4 pt-4">
                <a href="#store-products" class="px-8 py-4 bg-blue-600 hover:bg-blue-500 text-white rounded-full font-medium transition-colors shadow-[0_0_20px_rgba(37,99,235,0.4)]">
                    Mua Ngay
                </a>
                <button onclick="toggleAuthModal(true)" class="px-8 py-4 bg-white/10 hover:bg-white/20 text-white rounded-full font-medium backdrop-blur-sm transition-colors border border-white/10">
                    Đăng Ký Thành Viên
                </button>
            </div>
        </div>

        <div class="relative z-10 w-full max-w-[280px] sm:max-w-sm shrink-0 drop-shadow-2xl">
            <!-- Simulated high-tech device visual -->
            <svg viewBox="0 0 300 600" class="w-full h-auto" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <linearGradient id="titanium" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" stopColor="#4B4B4D" />
                        <stop offset="50%" stopColor="#2A2A2B" />
                        <stop offset="100%" stopColor="#1C1C1D" />
                    </linearGradient>
                    <linearGradient id="screen" x1="0%" y1="0%" x2="0%" y2="100%">
                        <stop offset="0%" stopColor="#1A1C23" />
                        <stop offset="100%" stopColor="#0B0D14" />
                    </linearGradient>
                </defs>

                <!-- Phone Body -->
                <rect x="10" y="10" width="280" height="580" rx="45" fill="url(#titanium)" stroke="#5A5A5C" stroke-width="2" />
                
                <!-- Screen -->
                <rect x="18" y="18" width="264" height="564" rx="38" fill="url(#screen)" />
                
                <!-- Dynamic Island -->
                <rect x="100" y="32" width="100" height="28" rx="14" fill="#000000" />
                <circle cx="120" cy="46" r="6" fill="#1A1A1A" />
                <circle cx="180" cy="46" r="4" fill="#0A0A0A" />

                <!-- Content Mockup: Apple Logo -->
                <path d="M150,280 C144,280 142,284 139,284 C136,284 133,280 128.5,280 C122.5,280 117.2,285.2 117.2,292.7 C117.2,301 122.5,307 128.5,307 C131.5,307 133.7,304.7 136,304.7 C138.2,304.7 139.7,307 143.5,307 C148.7,307 153.2,301 153.2,295 C153.2,293.5 151.7,292 150.2,291.2 C147.2,289.7 145.7,286.7 146.5,283.7 C147.2,280.7 149.2,280 150,280 Z" 
                    fill="white" opacity="0.1" />

                <!-- Light reflection -->
                <path d="M18,100 Q150,150 282,80 L282,18 A38,38 0 0,0 244,18 L56,18 A38,38 0 0,0 18,56 Z" 
                    fill="white" opacity="0.03" />
            </svg>
        </div>
    </div>

    <!-- CATEGORIES & PRODUCTS AREA -->
    <section id="store-products">
        <div class="flex items-center space-x-2 mb-8">
            <i data-lucide="sparkles" class="w-6 h-6 text-blue-500"></i>
            <h2 class="text-2xl font-semibold text-gray-900 tracking-tight">Danh mục sản phẩm</h2>
            <span class="text-sm font-medium text-gray-400 ml-2">(@(Model?.Count ?? 0) sản phẩm)</span>
        </div>

        <!-- Active Search Filter Indicator -->
        @if (!string.IsNullOrEmpty(searchQuery))
        {
            <div class="mb-6 inline-flex items-center space-x-2 bg-blue-50 border border-blue-100 text-blue-700 px-4 py-1.5 rounded-lg text-xs font-medium">
                <span>Kết quả tìm kiếm: "@searchQuery"</span>
                <a href="/" class="text-blue-500 hover:text-blue-900 font-bold ml-1">×</a>
            </div>
        }

        <!-- PRODUCTS GRID -->
        @if (Model == null || Model.Count == 0)
        {
            <div class="bg-white rounded-2xl border border-gray-100 p-20 text-center shadow-sm">
                <div class="inline-flex p-4 rounded-full bg-gray-50 text-gray-400 mb-4">
                    <i data-lucide="package-search" class="w-12 h-12"></i>
                </div>
                <h3 class="font-bold text-gray-900 text-lg">Không tìm thấy sản phẩm</h3>
                <p class="text-gray-500 text-xs mt-1">Xin vui lòng điều chỉnh bộ lọc hoặc từ khóa tìm kiếm của bạn.</p>
                <a href="/" class="inline-block mt-4 px-5 py-2.5 text-xs font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition shadow-md shadow-blue-500/10">Trở Về Trang Chủ</a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
                @foreach (var prod in Model)
                {
                    <div class="group relative bg-[#ffffff] rounded-3xl p-6 transition-all duration-500 hover:shadow-[0_20px_40px_rgb(0,0,0,0.06)] border border-transparent hover:border-gray-100 flex flex-col h-full overflow-hidden">
                        <!-- Subtle brand watermark -->
                        <div class="absolute -top-12 -right-12 text-[120px] font-black text-gray-50/50 -rotate-12 pointer-events-none select-none transition-transform duration-500 group-hover:scale-110 group-hover:-rotate-6">
                            @(prod.MaDanhMuc == "iphone" ? "iP" : "iP")
                        </div>

                        <a href="/Home/Detail/@prod.MaSanPham" class="relative w-full aspect-[4/5] bg-[#F5F5F7] rounded-2xl mb-8 overflow-hidden group-hover:bg-[#EAEAEA] transition-colors duration-500 flex items-center justify-center p-8 block">
                            <span class="absolute top-4 left-4 bg-white/60 backdrop-blur-md px-3 py-1 rounded-full text-[10px] font-bold text-gray-600 uppercase tracking-widest shadow-sm">
                                @prod.MaDanhMuc
                            </span>
                            <img src="/images/@prod.HinhAnh" alt="@prod.TenSanPham" class="w-full h-full object-contain filter drop-shadow-xl transition-transform duration-700 ease-out group-hover:scale-110" />
                            <!-- Shine effect -->
                            <div class="absolute inset-0 bg-gradient-to-tr from-white/0 via-white/20 to-white/0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 transform -translate-x-full group-hover:translate-x-full"></div>
                        </a>

                        <div class="relative flex flex-col flex-1 z-10">
                            <div class="flex-1">
                                <h3 class="text-lg font-semibold text-gray-900 leading-tight mb-2 group-hover:text-blue-600 transition-colors">
                                    <a href="/Home/Detail/@prod.MaSanPham">@prod.TenSanPham</a>
                                </h3>
                                <p class="text-sm text-gray-500 line-clamp-2 leading-relaxed">@prod.MoTa</p>
                            </div>

                            <div class="mt-8 flex items-end justify-between">
                                <div>
                                    <p class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-1">Giá bán</p>
                                    <p class="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-gray-900 to-gray-700">
                                        @String.Format("{0:N0} đ", prod.Gia)
                                    </p>
                                </div>
                                
                                <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                    <input type="hidden" name="productCode" value="@prod.MaSanPham" />
                                    <button type="submit" class="h-12 w-12 rounded-full bg-gray-900 text-white flex items-center justify-center hover:bg-blue-600 hover:shadow-lg hover:shadow-blue-500/20 active:scale-95 transition-all duration-300">
                                        <i data-lucide="shopping-cart" class="w-5 h-5"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>
</div>
