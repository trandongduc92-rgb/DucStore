@model List<DucStore_MVC.Models.SanPham>
@{
    var categories = ViewBag.Categories as List<DucStore_MVC.Models.DanhMuc> ?? new List<DanhMuc>();
    var selectedCategory = ViewBag.SelectedCategory as string;
    var searchQuery = ViewBag.SearchQuery as string;
}
@if (TempData["ShowPaymentQR"] != null)
{
    <div class="fixed inset-0 bg-black/60 flex items-center justify-center z-[9999]">

        <div class="bg-white rounded-3xl p-8 w-[430px] text-center shadow-2xl">

            <h2 class="text-2xl font-bold mb-2 text-gray-900">
                Thanh toán đơn hàng
            </h2>

            <p class="text-gray-500 mb-4">
                Mã đơn:
                <span class="font-bold text-blue-600">
                    @TempData["OrderCode"]
                </span>
            </p>

            <img src="/images/payment/qr-ducstore.jpg"
                 class="w-72 mx-auto rounded-xl border" />

            <div class="mt-5 space-y-2">

                <p class="text-lg font-bold text-red-600">
                    @TempData["OrderTotal"] đ
                </p>

                <p class="text-sm text-gray-600">
                    Nội dung chuyển khoản
                </p>

                <div class="bg-blue-50 rounded-lg py-2 font-bold text-blue-700">
                    @TempData["OrderCode"]
                </div>

            </div>

            <div class="mt-5 text-sm text-gray-500">
                Sau khi chuyển khoản thành công,
                Admin sẽ xác nhận đơn hàng và tiến hành giao hàng.
            </div>

            <button onclick="this.parentElement.parentElement.remove()"
                    class="mt-6 bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-xl">
                Tôi sẽ thanh toán
            </button>

        </div>

    </div>
}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-3 mt-3">
    <!-- SLIDER HERO BANNER - 2 SLIDES NO ARROWS -->
    <div class="relative overflow-hidden bg-[#121214] rounded-[1.5rem] shadow-2xl border border-white/5">

        <div id="heroSlider" class="flex transition-transform duration-700 ease-in-out">

            <!-- SLIDE 1: IPHONE -->
            <div class="min-w-full p-5 sm:p-7 md:p-9 flex flex-col md:flex-row items-center justify-between gap-6">

                <div class="relative z-10 max-w-xl space-y-3">
                    <span class="inline-flex items-center space-x-2 px-3 py-1 rounded-full text-xs font-semibold bg-blue-500/10 text-blue-400 border border-blue-500/20 uppercase tracking-widest text-[9px]">
                        <i data-lucide="sparkles" class="w-3.5 h-3.5 text-blue-400"></i>
                        <span>Sản phẩm hot</span>
                    </span>

                    <div class="space-y-2">
                        <h1 class="text-2xl sm:text-3xl md:text-4xl font-black tracking-tight text-white leading-none">
                            iPhone 17 Pro Max
                        </h1>
                        <p class="text-base sm:text-lg font-bold text-gray-200">
                            Vượt trội mọi giới hạn.
                        </p>
                    </div>

                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 pt-3">
                        <div class="flex items-center gap-2">
                            <i data-lucide="cpu" class="w-5 h-5 text-blue-400"></i>
                            <div>
                                <p class="text-[11px] font-bold text-white">Chip A19 Pro</p>
                                <p class="text-[10px] text-gray-400">Hiệu năng đỉnh cao</p>
                            </div>
                        </div>

                        <div class="flex items-center gap-2">
                            <i data-lucide="camera" class="w-5 h-5 text-blue-400"></i>
                            <div>
                                <p class="text-[11px] font-bold text-white">Camera 48MP</p>
                                <p class="text-[10px] text-gray-400">Telephoto 5x</p>
                            </div>
                        </div>

                        <div class="flex items-center gap-2">
                            <i data-lucide="battery-full" class="w-5 h-5 text-blue-400"></i>
                            <div>
                                <p class="text-[11px] font-bold text-white">Pin bền bỉ</p>
                                <p class="text-[10px] text-gray-400">Cả ngày dài</p>
                            </div>
                        </div>

                        <div class="flex items-center gap-2">
                            <i data-lucide="smartphone" class="w-5 h-5 text-blue-400"></i>
                            <div>
                                <p class="text-[11px] font-bold text-white">Màn hình 6.9"</p>
                                <p class="text-[10px] text-gray-400">Super Retina XDR</p>
                            </div>
                        </div>
                    </div>

                    <a href="#store-products" class="inline-flex mt-2 px-6 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-xs font-semibold rounded-full transition-all shadow-lg shadow-blue-500/20">
                        Khám phá ngay
                    </a>
                </div>

                <div class="relative z-10 w-full md:w-[430px] flex justify-center">
                    <div class="absolute right-0 bottom-3 w-[300px] h-[150px] bg-blue-600/20 blur-3xl rounded-full"></div>
                    <img src="/images/panel-iphone.png"
                         alt="iPhone 17 Pro Max"
                         class="relative h-[190px] sm:h-[220px] md:h-[250px] object-contain drop-shadow-2xl">
                </div>
            </div>

            <!-- SLIDE 2: IPAD -->
            <div class="min-w-full p-5 sm:p-7 md:p-9 flex flex-col md:flex-row items-center justify-between gap-6">

                <div class="relative z-10 max-w-xl space-y-3">
                    <span class="inline-flex items-center space-x-2 px-3 py-1 rounded-full text-xs font-semibold bg-blue-500/10 text-blue-400 border border-blue-500/20 uppercase tracking-widest text-[9px]">
                        <i data-lucide="sparkles" class="w-3.5 h-3.5 text-blue-400"></i>
                        <span>Sản phẩm hot</span>
                    </span>

                    <div class="space-y-2">
                        <h1 class="text-2xl sm:text-3xl md:text-4xl font-black tracking-tight text-white leading-none">
                            iPad Pro M4
                        </h1>
                        <p class="text-base sm:text-lg font-bold text-gray-200">
                            Mỏng. Nhẹ. Mạnh không tưởng.
                        </p>
                    </div>

                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 pt-3">
                        <div class="flex items-center gap-2">
                            <span class="w-5 h-5 border border-blue-400 text-blue-400 text-[10px] rounded flex items-center justify-center font-bold">M4</span>
                            <div>
                                <p class="text-[11px] font-bold text-white">Chip M4</p>
                                <p class="text-[10px] text-gray-400">Hiệu năng vượt trội</p>
                            </div>
                        </div>

                        <div class="flex items-center gap-2">
                            <i data-lucide="tablet" class="w-5 h-5 text-blue-400"></i>
                            <div>
                                <p class="text-[11px] font-bold text-white">Ultra Retina XDR</p>
                                <p class="text-[10px] text-gray-400">120Hz cực mượt</p>
                            </div>
                        </div>

                        <div class="flex items-center gap-2">
                            <i data-lucide="battery" class="w-5 h-5 text-blue-400"></i>
                            <div>
                                <p class="text-[11px] font-bold text-white">Pin lên đến</p>
                                <p class="text-[10px] text-gray-400">10 giờ</p>
                            </div>
                        </div>

                        <div class="flex items-center gap-2">
                            <i data-lucide="pen-tool" class="w-5 h-5 text-blue-400"></i>
                            <div>
                                <p class="text-[11px] font-bold text-white">Hỗ trợ</p>
                                <p class="text-[10px] text-gray-400">Apple Pencil Pro</p>
                            </div>
                        </div>
                    </div>

                    <a href="#store-products" class="inline-flex mt-2 px-6 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-xs font-semibold rounded-full transition-all shadow-lg shadow-blue-500/20">
                        Khám phá ngay
                    </a>
                </div>

                <div class="relative z-10 w-full md:w-[430px] flex justify-center">
                    <div class="absolute right-0 bottom-3 w-[300px] h-[150px] bg-blue-600/20 blur-3xl rounded-full"></div>
                    <img src="/images/panel-ipad.png"
                         alt="iPad Pro M4"
                         class="relative h-[190px] sm:h-[220px] md:h-[250px] object-contain drop-shadow-2xl">
                </div>
            </div>
        </div>

        <!-- DOTS -->
        <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex items-center space-x-2 z-20">
            <button type="button" onclick="goHeroSlide(0)" id="heroDot0" class="w-7 h-1.5 bg-blue-500 rounded-full transition-all"></button>
            <button type="button" onclick="goHeroSlide(1)" id="heroDot1" class="w-1.5 h-1.5 bg-gray-600 rounded-full transition-all"></button>
        </div>
    </div>

    <script>
            let heroIndex = 0;

            function goHeroSlide(index) {
                const slider = document.getElementById("heroSlider");
                const dot0 = document.getElementById("heroDot0");
                const dot1 = document.getElementById("heroDot1");

                heroIndex = index;
                slider.style.transform = `translateX(-${heroIndex * 100}%)`;
https://localhost:53297/images/panel-ipad.png
                if (heroIndex === 0) {
                    dot0.className = "w-7 h-1.5 bg-blue-500 rounded-full transition-all";
                    dot1.className = "w-1.5 h-1.5 bg-gray-600 rounded-full transition-all";
                } else {
                    dot0.className = "w-1.5 h-1.5 bg-gray-600 rounded-full transition-all";
                    dot1.className = "w-7 h-1.5 bg-blue-500 rounded-full transition-all";
                }
            }

            setInterval(function () {
                heroIndex = heroIndex === 0 ? 1 : 0;
                goHeroSlide(heroIndex);
            }, 4500);
    </script>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mt-2">

        <!-- Card 1 -->
        <div class="bg-white rounded-xl border border-gray-100 px-4 py-3 flex items-center gap-3 shadow-sm hover:shadow-md transition">

            <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center shrink-0">
                <i data-lucide="shield-check" class="w-4 h-4 text-blue-600"></i>
            </div>

            <div class="min-w-0">
                <h4 class="text-[13px] font-bold text-gray-900 leading-tight">
                    100% APPLE AUTHORIZED DEALER
                </h4>

                <p class="text-[11px] text-gray-500 leading-4 mt-1">
                    Hàng chính hãng VN/A • AppleCare chính hãng.
                </p>
            </div>

        </div>

        <!-- Card 2 -->
        <div class="bg-white rounded-xl border border-gray-100 px-4 py-3 flex items-center gap-3 shadow-sm hover:shadow-md transition">

            <div class="w-10 h-10 rounded-lg bg-amber-50 flex items-center justify-center shrink-0">
                <i data-lucide="zap" class="w-4 h-4 text-amber-600"></i>
            </div>

            <div class="min-w-0">
                <h4 class="text-[13px] font-bold text-gray-900 leading-tight">
                    GIAO NHANH TOÀN QUỐC
                </h4>

                <p class="text-[11px] text-gray-500 leading-4 mt-1">
                    Giao nhanh 2H tại Hà Nội & HCM.
                </p>
            </div>

        </div>

        <!-- Card 3 -->
        <div class="bg-white rounded-xl border border-gray-100 px-4 py-3 flex items-center gap-3 shadow-sm hover:shadow-md transition">

            <div class="w-10 h-10 rounded-lg bg-indigo-50 flex items-center justify-center shrink-0">
                <i data-lucide="award" class="w-4 h-4 text-indigo-600"></i>
            </div>

            <div class="min-w-0">
                <h4 class="text-[13px] font-bold text-gray-900 leading-tight">
                    BẢO HÀNH 1 ĐỔI 1
                </h4>

                <p class="text-[11px] text-gray-500 leading-4 mt-1">
                    Đổi mới trong 30 ngày nếu lỗi từ nhà sản xuất.
                </p>
            </div>

        </div>

    </div>

    <!-- CATEGORIES & PRODUCTS AREA -->
    <section id="store-products">
        <div class="flex items-center space-x-2 mb-3">
            <i data-lucide="sparkles" class="w-6 h-6 text-blue-500"></i>
            <h2 class="text-2xl font-semibold text-gray-900 tracking-tight">Danh mục sản phẩm</h2>
            <span class="text-sm font-medium text-gray-400 ml-2">(@(Model?.Count ?? 0) sản phẩm)</span>
        </div>

        <!-- Active Search Filter Indicator -->
        @if (!string.IsNullOrEmpty(searchQuery))
        {
            <div class="mb-6 inline-flex items-center space-x-2 bg-blue-50 border border-blue-100 text-blue-700 px-4 py-1.5 rounded-lg text-xs font-medium">
                <span>Kết quả tìm kiếm: "@searchQuery"</span>
                <a href="/" class="text-blue-500 hover:text-blue-900 font-bold ml-1">×</a>
            </div>
        }

        <!-- PRODUCTS GRID -->
        @if (Model == null || Model.Count == 0)
        {
            <div class="bg-white rounded-2xl border border-gray-100 p-20 text-center shadow-sm">
                <h3 class="font-bold text-gray-900 text-lg">Không tìm thấy sản phẩm</h3>
                <p class="text-gray-500 text-xs mt-1">Xin vui lòng điều chỉnh bộ lọc hoặc từ khóa tìm kiếm.</p>
            </div>
        }
        else
        {
            var displayProducts = Model.ToList();

            <div class="bg-[#202020] rounded-[1.5rem] p-4">
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4">

                    @foreach (var prod in displayProducts)
                    {
                        var name = prod.TenSanPham;

                        var capacities = name.Contains("iPhone 17 Pro Max") ? new[] { "256GB", "512GB", "1TB", "2TB" } :
                                         name.Contains("iPhone 17 Pro") ? new[] { "256GB", "512GB", "1TB" } :
                                         name.Contains("iPhone 17") ? new[] { "256GB", "512GB" } :
                                         name.Contains("iPhone 15 Plus") ? new[] { "128GB", "512GB" } :
                                         name.Contains("iPhone Air") ? new[] { "256GB", "512GB", "1TB" } :
                                         new[] { "128GB", "256GB", "512GB" };

                        var oldPrice = name.Contains("iPhone 17 Pro Max") ? "37.990.000đ" :
                                       name.Contains("iPhone 17 Pro") ? "34.990.000đ" :
                                       name.Contains("iPhone 17") ? "24.990.000đ" :
                                       name.Contains("iPhone 15 Plus") ? "21.990.000đ" :
                                       name.Contains("iPhone Air") ? "31.990.000đ" :
                                       "19.990.000đ";

                        var sale = name.Contains("iPhone 17 Pro Max") ? "-5%" :
                                   name.Contains("iPhone 17 Pro") ? "-3%" :
                                   name.Contains("iPhone 17") ? "-4%" :
                                   name.Contains("iPhone 15 Plus") ? "-18%" :
                                   name.Contains("iPhone Air") ? "-28%" :
                                   "-6%";

                        <div class="bg-[#2f2f2f] rounded-[1.4rem] p-4 shadow-lg hover:shadow-2xl transition-all duration-300 flex flex-col items-center min-h-[355px]">

                            <a href="/Home/Detail/@prod.MaSanPham"
                               class="w-full h-[190px] flex items-center justify-center mb-3">
                                <img src="/images/@prod.HinhAnh"
                                     alt="@prod.TenSanPham"
                                     class="max-h-[180px] w-full object-contain drop-shadow-xl transition-transform duration-500 hover:scale-105" />
                            </a>

                            <div class="flex justify-center flex-wrap gap-2 mb-4">
                                @foreach (var item in capacities)
                                {
                                    <span class="px-3 py-2 rounded-lg bg-[#181818] border border-gray-600 text-white text-xs">
                                        @item
                                    </span>
                                }
                            </div>

                            <h3 class="text-sm font-semibold text-white text-center leading-snug min-h-[36px]">
                                <a href="/Home/Detail/@prod.MaSanPham">
                                    @prod.TenSanPham
                                </a>
                            </h3>

                            <div class="flex items-center justify-center gap-1 mt-3 flex-wrap">
                                <span class="text-white text-base font-black">
                                    @String.Format("{0:N0}đ", prod.Gia)
                                </span>

                                <span class="text-gray-300 text-xs line-through">
                                    @oldPrice
                                </span>

                                <span class="text-white text-xs">
                                    @sale
                                </span>
                            </div>

                            @if (name.Contains("iPhone Air") || name.Contains("iPhone 17 Pro"))
                            {
                                <p class="text-yellow-400 text-xs mt-3">
                                    Online giá rẻ quá
                                </p>
                            }

                            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="w-full mt-auto pt-4">
                                <input type="hidden" name="productCode" value="@prod.MaSanPham" />
                                <button type="submit"
                                        class="w-full py-2.5 bg-[#111111] hover:bg-black text-white font-bold text-xs rounded-xl flex items-center justify-center gap-2 transition">
                                    <i data-lucide="shopping-cart" class="w-4 h-4"></i>
                                    <span>Thêm vào giỏ hàng</span>
                                </button>
                            </form>

                        </div>
                    }

                </div>
            </div>
        }
</div>
